{
  "description": "SDD 硬约束 hooks：propose 前扫 [TBD] 必须清空、apply 前查 proposal 必须存在",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/check-tbd.sh"
            ],
            "timeout": 10
          },
          {
            "type": "command",
            "command": "sh",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/check-gate.sh"
            ],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
