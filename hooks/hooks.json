{
  "description": "SDD hard-constraint hooks: before propose, scan that [TBD] is cleared; before apply, check that the APPROVED marker exists",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": [
              "-NoProfile",
              "-NonInteractive",
              "-File",
              "${CLAUDE_PLUGIN_ROOT}/hooks/check-tbd.ps1"
            ],
            "timeout": 10
          },
          {
            "type": "command",
            "command": "pwsh",
            "args": [
              "-NoProfile",
              "-NonInteractive",
              "-File",
              "${CLAUDE_PLUGIN_ROOT}/hooks/check-gate.ps1"
            ],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
