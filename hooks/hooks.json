{
  "description": "SDD hooks: 3 UserPromptSubmit gates (propose: [TBD] cleared; apply: prerequisites ready — proposal with all four sections + single active change; archive: flow wasn't bypassed) + 1 Stop reminder (turn ended with approved proposal but no verification ledger)",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": [
              "-NoProfile",
              "-NonInteractive",
              "-File",
              "${CLAUDE_PLUGIN_ROOT}/hooks/check-tbd.ps1"
            ],
            "timeout": 10
          },
          {
            "type": "command",
            "command": "pwsh",
            "args": [
              "-NoProfile",
              "-NonInteractive",
              "-File",
              "${CLAUDE_PLUGIN_ROOT}/hooks/check-gate.ps1"
            ],
            "timeout": 10
          },
          {
            "type": "command",
            "command": "pwsh",
            "args": [
              "-NoProfile",
              "-NonInteractive",
              "-File",
              "${CLAUDE_PLUGIN_ROOT}/hooks/check-archive.ps1"
            ],
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": [
              "-NoProfile",
              "-NonInteractive",
              "-File",
              "${CLAUDE_PLUGIN_ROOT}/hooks/check-verify-reminder.ps1"
            ],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
