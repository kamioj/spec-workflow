{
  "description": "SDD 硬约束 hooks：propose 前扫 [TBD] 必须清空、apply 前查 APPROVED 标记必须存在",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": [
              "-NoProfile",
              "-NonInteractive",
              "-File",
              "${CLAUDE_PLUGIN_ROOT}/hooks/check-tbd.ps1"
            ],
            "timeout": 10
          },
          {
            "type": "command",
            "command": "pwsh",
            "args": [
              "-NoProfile",
              "-NonInteractive",
              "-File",
              "${CLAUDE_PLUGIN_ROOT}/hooks/check-gate.ps1"
            ],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
