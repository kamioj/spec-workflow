{
  "description": "SDD 硬约束 hooks：propose 前扫 [TBD] 必须清空（UserPromptSubmit）；写 spec/ 外源码前查契约已批准且指纹未漂移（PreToolUse 动作级门，决策→实施 边界）",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": [
              "-NoProfile",
              "-NonInteractive",
              "-File",
              "${CLAUDE_PLUGIN_ROOT}/hooks/check-tbd.ps1"
            ],
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": [
              "-NoProfile",
              "-NonInteractive",
              "-File",
              "${CLAUDE_PLUGIN_ROOT}/hooks/check-source-gate.ps1"
            ],
            "timeout": 15
          }
        ]
      }
    ]
  }
}
